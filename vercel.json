{
  "rewrites": [
    { "source": "/vip", "destination": "/vip.html" },
    { "source": "/catalogue", "destination": "/catalogue.html" },
    { "source": "/apropos", "destination": "/apropos.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
